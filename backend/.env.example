# =============================================================================
# Shankar Card AI Image Enhancer — production env (Oracle Cloud Always Free)
# Copy to backend/.env before: docker compose up -d --build
# =============================================================================

# Background removal: local (unlimited BiRefNet) | removebg (paid API)
BG_PROVIDER=local
BIREFNET_MODEL=birefnet-general-lite
BIREFNET_MAX_SIDE=768
BIREFNET_PAD=24

# Required only when BG_PROVIDER=removebg
REMOVE_BG_API_KEY=
REMOVE_BG_SIZE=hd
REMOVE_BG_TYPE=animal

# Memory-safe caps for Always Free Ampere (recommend ≥8 GB RAM on the VM)
SAFE_INPUT_SIDE=1600
MAX_PROCESS_SIDE=1000
MAX_OUTPUT_SIDE=2800
MAX_FILE_SIZE_MB=20

# Real-ESRGAN (CPU, small tiles)
REALESRGAN_SCALE=2
REALESRGAN_TILE=128
REALESRGAN_THREADS=2
REALESRGAN_FAST_4X=true
REALESRGAN_2X_MAX_INPUT=1000
REALESRGAN_4X_MAX_INPUT=640

PERFORMANCE_PROFILE=low
DEVICE=cpu
USE_TORCH_REALESRGAN=true
USE_GFPGAN_MODEL=false
UNLOAD_MODELS_AFTER_USE=true

# Same-origin behind Nginx → * is fine. Or set https://your-domain.com
CORS_ORIGINS=*

# Optional compose override (GB). Ampere with 24 GB can use 16g.
# APP_MEM_LIMIT=8g
