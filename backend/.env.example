# Background removal: local (unlimited) | removebg (paid API)
BG_PROVIDER=local
BIREFNET_MODEL=birefnet-general-lite
BIREFNET_MAX_SIDE=896
BIREFNET_PAD=32

# Required only when BG_PROVIDER=removebg
REMOVE_BG_API_KEY=
REMOVE_BG_SIZE=hd
REMOVE_BG_TYPE=animal

# Cap inputs for ~8GB RAM machines
SAFE_INPUT_SIDE=1800

# Real-ESRGAN
REALESRGAN_SCALE=2
REALESRGAN_TILE=128
REALESRGAN_THREADS=2
REALESRGAN_FAST_4X=true
REALESRGAN_2X_MAX_INPUT=1100
REALESRGAN_4X_MAX_INPUT=720

PERFORMANCE_PROFILE=low
DEVICE=cpu
MAX_PROCESS_SIDE=1100
MAX_OUTPUT_SIDE=3200
USE_TORCH_REALESRGAN=true
USE_GFPGAN_MODEL=false
UNLOAD_MODELS_AFTER_USE=true
MAX_FILE_SIZE_MB=20

# Comma-separated frontend origins, or * for same-server / open CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
