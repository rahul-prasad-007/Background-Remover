# Build context hygiene — keep image small & builds fast
.git
.gitignore
.venv
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Local envs / secrets (compose still mounts backend/.env via env_file)
.env
.env.*
!.env.example
!backend/.env.example
backend/.env

# Frontend deps & build (rebuilt inside Docker)
frontend/node_modules
frontend/dist
frontend/.vite

# Runtime data & large local weights (downloaded in volume on first use)
backend/uploads/**
!backend/uploads/.gitkeep
backend/outputs/**
!backend/outputs/.gitkeep
backend/weights/**
!backend/weights/.gitkeep
backend/static/**
!backend/static/.gitkeep
backend/.venv

# Docs / IDE / OS
*.md
!README.md
.idea
.vscode
**/.DS_Store
**/Thumbs.db
*.log
*.pth
*.onnx

# Nested compose leftovers
deploy/*.pem
deploy/*.key
